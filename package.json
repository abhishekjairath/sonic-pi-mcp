{
  "name": "sonic-pi-mcp",
  "version": "2.0.0",
  "description": "MCP server for Sonic Pi: natural-language DJ sessions, OSC, queue runner, tools and prompts",
  "type": "module",
  "author": "Abhishek Jairath",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhishekjairath/sonic-pi-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/abhishekjairath/sonic-pi-mcp/issues"
  },
  "homepage": "https://github.com/abhishekjairath/sonic-pi-mcp#readme",
  "keywords": [
    "mcp",
    "sonic-pi",
    "ai",
    "llm",
    "music",
    "claude",
    "dj"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "sonic-pi-mcp": "bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "sonic-pi-queue.rb",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/server.ts --outfile dist/server.mjs --target node --format esm --packages external",
    "prepack": "bun run build",
    "dev": "bun run src/server.ts",
    "start": "node bin/cli.mjs",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "test": "bun run src/test.ts",
    "release": "release-it --config scripts/release-it/config.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "node-osc": "^8.0.12",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.11.24",
    "@types/node-osc": "^9.1.0",
    "release-it": "^19.2.4"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
